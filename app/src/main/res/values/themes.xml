<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Pilem" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>

    <!-- Theme khusus tanpa action bar -->
    <style name="Theme.Pilem.NoActionBar" parent="Theme.Pilem">
        <item name="android:windowActionBar">false</item>
        <item name="android:windowNoTitle">true</item>
    </style>

    <!-- Overlay menggunakan Material3 agar konsisten -->
    <style name="Theme.Pilem.AppBarOverlay" parent="ThemeOverlay.Material3.Dark.ActionBar" />

    <style name="Theme.Pilem.PopupOverlay" parent="ThemeOverlay.Material3.Light" />
</resources>
